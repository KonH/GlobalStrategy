# Temporary scripts
.tmp/
__pycache__/

# Ralph loop metrics (per-run, not shared)
.ralph/metrics*.csv

# Unity generated
Library/
Temp/
Obj/
Build/
Builds/
Logs/
UserSettings/
MemoryCaptures/
Recordings/

# Unity cache
[Cc]rashes/
[Ee]xportedObj/
*.pidb
*.unityproj
*.suo
*.tmp
*.user
*.userprefs
*.booproj
*.svd
*.pdb
*.mdb
*.opendb
*.VC.db

# OS generated
.DS_Store
Thumbs.db

# Visual Studio / Rider
.vs/
.idea/
*.csproj
*.sln

# src/ C# solution — track project files, ignore build artifacts
!src/**/*.csproj
!src/**/*.sln
src/**/bin/
src/**/obj/

# BenchmarkDotNet's own raw per-run artifacts (generated exe copies, exported reports) —
# Docs/Benchmarks/{baseline.json,history.json,summary.md} are the harness's own committed
# snapshots and are tracked normally, not covered by this rule.
BenchmarkDotNet.Artifacts/

# Packages lock (optional: keep if you want reproducible builds)
# Packages/packages-lock.json
.claude/settings.local.json
.venv
ComfyUI/
Packages/com.unity.ide.rider
