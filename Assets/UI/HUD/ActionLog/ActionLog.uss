.action-log-root {
    width: 100%;
    height: 100%;
    overflow: hidden;
}

.action-log-content {
    flex-direction: column;
    justify-content: flex-end;
    height: 100%;
    width: 100%;
}

.action-log-entry {
    white-space: normal;
    margin-top: 4px;
    color: rgb(255, 255, 255);
    text-shadow: 3px 3px 0 rgba(0, 0, 0, 1);
}
