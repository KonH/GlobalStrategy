<ui:UXML xmlns:ui="UnityEngine.UIElements" editor-extension-mode="False">
    <ui:Style src="project://database/Assets/UI/Shared/SharedStyles.uss"/>
    <ui:Style src="project://database/Assets/UI/Overlay/OrgInfo/OrgInfo.uss"/>
    <ui:Style src="project://database/Assets/UI/Overlay/OrgInfo/OrgActions.uss"/>
    <ui:Style src="project://database/Assets/UI/HUD/CountryInfo/CountryInfo.uss" />
    <ui:VisualElement name="characters-slide" class="characters-slide">
        <ui:VisualElement name="characters-container" class="characters-container" />
    </ui:VisualElement>
    <ui:VisualElement name="actions-slide" class="actions-slide">
        <ui:VisualElement name="actions-instance">
            <ui:VisualElement name="hand-container" class="hand-container" />
        </ui:VisualElement>
    </ui:VisualElement>
    <ui:VisualElement name="country-bar" class="country-bar">
        <ui:VisualElement name="country-main-block" class="country-main-block">
            <ui:VisualElement name="country-name-row" class="flag-name-row">
                <ui:VisualElement name="country-flag" class="entity-flag" picking-mode="Ignore" />
                <ui:Label name="country-name" class="country-name" text="" />
            </ui:VisualElement>
            <ui:VisualElement name="influence-row" style="flex-direction: row; align-items: center;">
                <ui:VisualElement class="influence-icon" />
                <ui:Label name="influence-label" class="gs-label" text="" />
            </ui:VisualElement>
            <ui:VisualElement name="resources-container" class="resources-container" />
        </ui:VisualElement>
        <ui:VisualElement class="country-toggle-block">
            <ui:Button name="chars-toggle-btn" class="chars-toggle-btn gs-btn gs-btn--small">
                <ui:VisualElement class="org-toggle-btn-icon org-toggle-btn-icon--characters" picking-mode="Ignore" />
                <ui:Label text="Characters &#x25B2;" picking-mode="Ignore" />
            </ui:Button>
            <ui:Button name="actions-toggle-btn" class="chars-toggle-btn gs-btn gs-btn--small">
                <ui:VisualElement class="org-toggle-btn-icon org-toggle-btn-icon--actions" picking-mode="Ignore" />
                <ui:Label text="Actions &#x25B2;" picking-mode="Ignore" />
            </ui:Button>
        </ui:VisualElement>
    </ui:VisualElement>
</ui:UXML>
