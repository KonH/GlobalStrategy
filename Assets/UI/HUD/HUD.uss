#hud-root {
    width: 100%;
    height: 100%;
    position: absolute;
}

.time-panel {
    position: absolute;
    top: 0;
    right: 0;
}

.country-info-panel {
    position: absolute;
    bottom: 0;
    left: 0;
    right: 0;
    height: 80px;
    background-color: rgba(0, 0, 0, 0.7);
    padding: 8px 16px;
    flex-direction: row;
    align-items: center;
}
