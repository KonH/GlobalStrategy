<ui:UXML xmlns:ui="UnityEngine.UIElements" editor-extension-mode="False">
    <ui:Style src="project://database/Assets/UI/Shared/SharedStyles.uss"/>
    <ui:Style src="project://database/Assets/UI/HUD/OrgLensCountryInfo/OrgLensCountryInfo.uss"/>
    <ui:VisualElement name="org-lens-country-bar" class="org-lens-country-bar">
        <ui:VisualElement name="org-name-row" class="flag-name-row">
            <ui:VisualElement name="org-flag" class="entity-flag" picking-mode="Ignore" />
            <ui:Label name="org-name" class="gs-label" text="" />
        </ui:VisualElement>
        <ui:Label name="org-no-dominant" class="gs-hint" text="No dominant organization" />
    </ui:VisualElement>
</ui:UXML>
