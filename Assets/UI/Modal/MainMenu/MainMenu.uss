.main-menu-root {
    position: absolute;
    left: 0;
    top: 0;
    right: 0;
    bottom: 0;
    flex-direction: column;
    align-items: center;
    justify-content: center;
}

.menu-panel {
    position: relative;
    padding: 40px 28px;
    width: 300px;
}

.menu-title {
    font-size: 48px;
    margin-bottom: 24px;
    white-space: normal;
    -unity-text-align: middle-center;
}

.menu-button {
    width: 100%;
}
