<ui:UXML xmlns:ui="UnityEngine.UIElements" editor-extension-mode="False">
    <ui:Style src="project://database/Assets/UI/Shared/SharedStyles.uss"/>
    <ui:Style src="project://database/Assets/UI/Modal/MainMenu/MainMenu.uss"/>
    <ui:VisualElement name="main-menu-root" class="main-menu-root">
        <ui:VisualElement name="blackfade" class="gs-blackfade"/>
        <ui:VisualElement name="menu-panel" class="gs-panel menu-panel">
            <ui:Label name="title-label" text="Global Strategy" class="gs-title menu-title"/>
            <ui:Button name="btn-play" text="Play" class="gs-btn gs-btn--primary menu-button"/>
            <ui:Button name="btn-resume" text="Resume" class="gs-btn gs-btn--primary menu-button"/>
            <ui:Button name="btn-load" text="Load" class="gs-btn gs-btn--primary menu-button"/>
            <ui:Button name="btn-settings" text="Settings" class="gs-btn gs-btn--primary menu-button"/>
            <ui:Button name="btn-exit" text="Exit" class="gs-btn gs-btn--primary menu-button"/>
        </ui:VisualElement>
    </ui:VisualElement>
</ui:UXML>
