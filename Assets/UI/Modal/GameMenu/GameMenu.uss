.game-menu-root {
    position: absolute;
    left: 0;
    top: 0;
    right: 0;
    bottom: 0;
    align-items: center;
    justify-content: center;
}

.menu-panel {
    position: relative;
    padding: 32px 44px;
    min-width: 260px;
}

.menu-title {
    margin-bottom: 26px;
}

.menu-button {
    width: 280px;
    height: 58px;
    margin-bottom: 14px;
    font-size: 30px;
}
