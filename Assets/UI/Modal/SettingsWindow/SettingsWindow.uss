.window-panel {
    padding: 28px 36px;
    min-width: 340px;
}

.window-title {
    margin-bottom: 24px;
}

.setting-row {
    flex-direction: row;
    align-items: center;
    width: 100%;
    margin-bottom: 16px;
}

.setting-label {
    width: 120px;
}

.setting-buttons {
    flex-direction: row;
    flex-grow: 1;
}

.setting-button {
    flex-grow: 1;
    height: 44px;
    margin-right: 6px;
}

.menu-button {
    width: 200px;
    height: 52px;
    margin-top: 20px;
    font-size: 28px;
}
